# OntoBranch-2026 .gitignore

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Jupyter Notebook
.ipynb_checkpoints

# PyTorch
*.pth
*.pt

# Experiments & Logs
experiments/logs/
experiments/checkpoints/*.pth
experiments/results/*.json
*.log

# Data (保护隐私)
data/raw/*
data/processed/*
!data/raw/.gitkeep
!data/processed/.gitkeep

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Environment
.env
.venv
env/
venv/

# Weights & Biases
wandb/

# Gurobi
gurobi.log
*.lp
*.mps
*.sol

# SCIP
*.scip
